(export (version "E")
  (design (source "board.py") (tool "hitscan-gen"))
  (components
    (comp (ref "J4") (value "ESP32_left")
      (footprint "Connector_PinSocket_2.54mm:PinSocket_1x15_P2.54mm_Vertical"))
    (comp (ref "J5") (value "ESP32_right")
      (footprint "Connector_PinSocket_2.54mm:PinSocket_1x15_P2.54mm_Vertical"))
    (comp (ref "J1") (value "PAD_CHEST")
      (footprint "TerminalBlock:TerminalBlock_bornier-2_P5.08mm"))
    (comp (ref "J2") (value "PAD_BACK")
      (footprint "TerminalBlock:TerminalBlock_bornier-2_P5.08mm"))
    (comp (ref "J3") (value "RING_LED")
      (footprint "Connector_PinHeader_2.54mm:PinHeader_1x03_P2.54mm_Vertical"))
    (comp (ref "R1") (value "22R 0.5W")
      (footprint "Resistor_THT:R_Axial_DIN0309_L9.0mm_D3.2mm_P12.70mm_Horizontal"))
    (comp (ref "R2") (value "1R")
      (footprint "Resistor_THT:R_Axial_DIN0207_L6.3mm_D2.5mm_P10.16mm_Horizontal"))
    (comp (ref "BZ1") (value "active_buzzer")
      (footprint "Buzzer_Beeper:Buzzer_12x9.5RM7.6"))
    (comp (ref "SW1") (value "reset")
      (footprint "Button_Switch_THT:SW_PUSH_6mm"))
    (comp (ref "H1") (value "M3")
      (footprint "MountingHole:MountingHole_3.2mm_M3"))
    (comp (ref "H2") (value "M3")
      (footprint "MountingHole:MountingHole_3.2mm_M3"))
    (comp (ref "H3") (value "M3")
      (footprint "MountingHole:MountingHole_3.2mm_M3"))
    (comp (ref "H4") (value "M3")
      (footprint "MountingHole:MountingHole_3.2mm_M3"))
  )
  (nets
    (net (code "1") (name "3V3")
      (node (ref "J5") (pin "15"))
      (node (ref "R1") (pin "1"))
    )
    (net (code "2") (name "PAD_HI")
      (node (ref "R1") (pin "2"))
      (node (ref "J1") (pin "1"))
      (node (ref "J2") (pin "1"))
    )
    (net (code "3") (name "P32")
      (node (ref "J4") (pin "6"))
      (node (ref "R2") (pin "1"))
      (node (ref "J1") (pin "2"))
      (node (ref "J2") (pin "2"))
    )
    (net (code "4") (name "GND")
      (node (ref "J4") (pin "14"))
      (node (ref "J5") (pin "14"))
      (node (ref "R2") (pin "2"))
      (node (ref "BZ1") (pin "2"))
      (node (ref "SW1") (pin "2"))
      (node (ref "J3") (pin "2"))
    )
    (net (code "5") (name "VIN")
      (node (ref "J4") (pin "15"))
      (node (ref "J3") (pin "1"))
    )
    (net (code "6") (name "P5")
      (node (ref "J5") (pin "8"))
      (node (ref "J3") (pin "3"))
    )
    (net (code "7") (name "P18")
      (node (ref "J5") (pin "7"))
      (node (ref "BZ1") (pin "1"))
    )
    (net (code "8") (name "P19")
      (node (ref "J5") (pin "6"))
      (node (ref "SW1") (pin "1"))
    )
  ))
